---
import type { Lang } from '../utils/i18n';
import { getContent, getLocalizedPath } from '../utils/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getContent(lang);
const homeHref = getLocalizedPath(lang);
const altLangHref = lang === 'en' ? getLocalizedPath('es') : getLocalizedPath('en');
---

<header class="navbar-container">
  <a class="logo-container" href={homeHref} aria-label={t.nav.homeLabel}>
    <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <circle cx="20" cy="20" r="18" stroke="white" stroke-width="2" opacity="0.6" />
      <circle cx="20" cy="20" r="10" fill="white" opacity="0.15" />
      <circle cx="20" cy="20" r="4" fill="white" opacity="0.8" />
      <line x1="2" y1="20" x2="8" y2="20" stroke="white" stroke-width="1.5" opacity="0.5" />
      <line x1="32" y1="20" x2="38" y2="20" stroke="white" stroke-width="1.5" opacity="0.5" />
      <line x1="20" y1="2" x2="20" y2="8" stroke="white" stroke-width="1.5" opacity="0.5" />
      <line x1="20" y1="32" x2="20" y2="38" stroke="white" stroke-width="1.5" opacity="0.5" />
    </svg>
    <p>SatScale</p>
  </a>

  <nav aria-label={t.nav.primaryNavLabel} class="navbar-nav">
    <button
      type="button"
      class="burger-button"
      aria-expanded="false"
      aria-controls="navbar-menu"
      data-menu-toggle
    >
      <span class="visually-hidden" data-menu-label-open>{t.nav.openMenu}</span>
      <span class="visually-hidden" data-menu-label-close>{t.nav.closeMenu}</span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>

    <div class="navbar-panel" id="navbar-menu" hidden>
      <ul class="navbar-pages-container">
        <li class="navbar-page">
          <a href="#how-it-works">{t.nav.howItWorks}</a>
        </li>
        <li class="navbar-page">
          <a href="#demo">{t.nav.demo}</a>
        </li>
        <li class="navbar-page">
          <a href="#trust">{t.nav.trust}</a>
        </li>
        <li class="navbar-page">
          <a href="#contact">{t.nav.contact}</a>
        </li>
        <li class="navbar-language-item">
          <span>{t.nav.language}</span>
          <div class="language-switcher" aria-label={t.nav.language}>
            <a href={getLocalizedPath('es')} aria-current={lang === 'es' ? 'page' : undefined}>ES</a>
            <a href={getLocalizedPath('en')} aria-current={lang === 'en' ? 'page' : undefined}>EN</a>
          </div>
        </li>
      </ul>
      <a class="navbar-alt-link" href={altLangHref}>
        {lang === 'en' ? 'Ver version en espanol' : 'View English version'}
      </a>
    </div>
  </nav>
</header>
<div class="navbar-footer" aria-hidden="true"></div>

<script>
  if (typeof window !== 'undefined') {
    window.addEventListener('DOMContentLoaded', () => {
      const burger = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
      const panel = document.querySelector<HTMLElement>('#navbar-menu');
      const nav = document.querySelector<HTMLElement>('.navbar-nav');

      if (!burger || !panel || !nav) return;

      const mq = window.matchMedia('(max-width: 767px)');
      const menuLinks = Array.from(panel.querySelectorAll<HTMLAnchorElement>('a'));
      const openLabel = burger.querySelector<HTMLElement>('[data-menu-label-open]');
      const closeLabel = burger.querySelector<HTMLElement>('[data-menu-label-close]');

      const syncButtonLabel = (expanded: boolean) => {
        const label = expanded ? closeLabel?.textContent : openLabel?.textContent;
        if (label) burger.setAttribute('aria-label', label);
      };

      const setMenuState = (expanded: boolean, restoreFocus = false) => {
        burger.classList.toggle('active', expanded);
        burger.setAttribute('aria-expanded', String(expanded));
        syncButtonLabel(expanded);

        if (mq.matches) {
          panel.hidden = !expanded;
          document.body.classList.toggle('menu-open', expanded);
          if (expanded) {
            menuLinks[0]?.focus();
          } else if (restoreFocus) {
            burger.focus();
          }
        } else {
          panel.hidden = false;
          document.body.classList.remove('menu-open');
        }
      };

      const closeMenu = (restoreFocus = false) => {
        if (!mq.matches) return;
        setMenuState(false, restoreFocus);
      };

      const syncViewport = () => {
        if (mq.matches) {
          panel.hidden = burger.getAttribute('aria-expanded') !== 'true';
        } else {
          setMenuState(false);
        }
      };

      burger.addEventListener('click', () => {
        if (!mq.matches) return;
        const nextState = burger.getAttribute('aria-expanded') !== 'true';
        setMenuState(nextState);
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') closeMenu(true);
      });

      document.addEventListener('click', (event) => {
        if (!mq.matches || burger.getAttribute('aria-expanded') !== 'true') return;
        const target = event.target as Node | null;
        if (target && nav.contains(target)) return;
        closeMenu();
      });

      menuLinks.forEach((link) => {
        link.addEventListener('click', () => closeMenu());
      });

      mq.addEventListener('change', syncViewport);
      syncButtonLabel(false);
      syncViewport();
    });
  }
</script>
