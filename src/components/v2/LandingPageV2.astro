---
import PageLayoutV2 from '../../layouts/PageLayoutV2.astro';
import type { Lang } from '../../utils/i18n';
import { getContent } from '../../utils/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getContent(lang);
const endpoint = import.meta.env.PUBLIC_CONTACT_FORM_ENDPOINT?.trim() ?? '';
const fallbackEmail = 'contact@satscale.ai';
const path = lang === 'en' ? '/v2/en/' : '/v2/';
const alternateLinks = [
  { lang: 'es', path: '/v2/' },
  { lang: 'en', path: '/v2/en/' }
];
const copy = lang === 'en'
  ? {
      nav: {
        technology: 'Technology',
        showcase: 'Showcase',
        pricing: 'Pricing',
        enterprise: 'Enterprise',
        getStarted: 'Get Started'
      },
      language: 'Language',
      tech: {
        title: 'The Science of <br />Optical Restoration',
        body:
          'SatScale leverages sub-pixel convolutional neural networks to reconstruct missing structural details from raw satellite data, surpassing the diffraction limit of physical optics.',
        features: [
          {
            icon: 'auto_awesome',
            title: 'Sub-Pixel Synthesis',
            body: 'Reconstructing textural density where sensors only captured noise.'
          },
          {
            icon: 'blur_off',
            title: 'De-Hazing Engine',
            body: 'Intelligent removal of cloud artifacts and spectral scattering.'
          }
        ]
      },
      comparison: {
        title: 'The Precision Benchmarks',
        body:
          'Compare raw 30cm/pixel imagery against SatScale Zenith 5cm/pixel synthesized enhancement.',
        synthetic: 'Synthetic (5cm/px)',
        raw: 'Raw Data (30cm/px)'
      },
      footer: {
        privacy: 'Privacy Protocol',
        terms: 'Terms of Deployment',
        status: 'System Status',
        contact: 'Contact Ops',
        copy: '© 2026 SAT-SCALE AI. DATA PRECISION GUARANTEED.'
      },
      form: {
        kicker: 'Demo Request',
        title: 'Get in touch',
        intro: '',
        requestLabel: 'What do you need?',
        requestOptions: [
          ['demo', 'Book a demo'],
          ['info', 'More product information'],
          ['scheduling', 'Schedule a meeting'],
          ['pricing', 'Discuss pricing'],
          ['enterprise', 'Enterprise evaluation']
        ],
        teamLabel: 'Team or organization',
        teamPlaceholder: 'Company, agency, or lab name',
        useCaseLabel: 'What do you want to review?',
        useCasePlaceholder: 'Example: urban imagery, private evaluation, technical questions, procurement scope, or integration needs.',
        submit: 'Send request',
        fallbackNotice: t.contact.fallbackNotice,
        success: t.contact.success,
        error: t.contact.error,
        busy: t.contact.submitBusy,
        privacy: t.contact.privacyNote,
        subjectPrefix: 'SatScale V2'
      },
      alts: {
        hero: 'Aerial satellite view of a coastal city at night',
        techOne: 'Neural network processing visualization',
        techTwo: 'Abstract data flow visualization',
        comparisonBack: 'High resolution harbor satellite image',
        comparisonFront: 'Low resolution harbor satellite image',
        verticalOne: 'Aerial view of urban highway interchange',
        verticalTwo: 'Aerial view of green agricultural fields',
        verticalThree: 'Melting glacier aerial view',
        verticalFour: 'Global world map with data points'
      }
    }
  : {
      nav: {
        technology: 'Tecnologia',
        showcase: 'Resultados',
        pricing: 'Planes',
        enterprise: 'Empresas',
        getStarted: 'Comenzar'
      },
      language: 'Idioma',
      tech: {
        title: 'La ciencia de la <br />restauracion optica',
        body:
          'SatScale utiliza redes neuronales de sub-pixel para reconstruir detalle estructural a partir de datos satelitales crudos y mejorar la lectura operativa de cada escena.',
        features: [
          {
            icon: 'auto_awesome',
            title: 'Sintesis sub-pixel',
            body: 'Reconstruye densidad textural donde los sensores solo capturaron ruido.'
          },
          {
            icon: 'blur_off',
            title: 'Motor de desneblinado',
            body: 'Reduce nubosidad, haze y dispersion espectral para una lectura mas limpia.'
          }
        ]
      },
      comparison: {
        title: 'Benchmarks de precision',
        body:
          'Compara imagery base de 30 cm/pixel con la salida sintetica equivalente a 5 cm/pixel del motor SatScale Zenith.',
        synthetic: 'Sintetica (5cm/px)',
        raw: 'Dato crudo (30cm/px)'
      },
      footer: {
        privacy: 'Protocolo de privacidad',
        terms: 'Condiciones de despliegue',
        status: 'Estado del sistema',
        contact: 'Contactar operaciones',
        copy: '© 2026 SAT-SCALE AI. PRECISION DE DATOS GARANTIZADA.'
      },
      form: {
        kicker: 'Solicitud de demo',
        title: 'Hablemos',
        intro: '',
        requestLabel: 'Que necesitas',
        requestOptions: [
          ['demo', 'Agendar una demo'],
          ['info', 'Mas informacion del producto'],
          ['scheduling', 'Agendar una reunion'],
          ['pricing', 'Hablar de precios'],
          ['enterprise', 'Evaluacion enterprise']
        ],
        teamLabel: 'Equipo u organizacion',
        teamPlaceholder: 'Nombre de empresa, agencia o laboratorio',
        useCaseLabel: 'Que quieres revisar',
        useCasePlaceholder: 'Ejemplo: imagery urbana, evaluacion privada, dudas tecnicas, alcance comercial o integracion.',
        submit: 'Enviar solicitud',
        fallbackNotice: t.contact.fallbackNotice,
        success: t.contact.success,
        error: t.contact.error,
        busy: t.contact.submitBusy,
        privacy: t.contact.privacyNote,
        subjectPrefix: 'SatScale V2'
      },
      alts: {
        hero: 'Vista satelital aerea de una ciudad costera en la noche',
        techOne: 'Visualizacion del procesamiento neuronal',
        techTwo: 'Visualizacion abstracta de flujo de datos',
        comparisonBack: 'Imagen satelital de puerto en alta resolucion',
        comparisonFront: 'Imagen satelital de puerto en baja resolucion',
        verticalOne: 'Vista aerea de un intercambiador urbano',
        verticalTwo: 'Vista aerea de campos agricolas',
        verticalThree: 'Vista aerea de un glaciar en deshielo',
        verticalFour: 'Mapa global con nodos de datos'
      }
    };
---

<PageLayoutV2
  title={t.seo.title}
  description={t.seo.description}
  lang={lang}
  path={path}
  alternateLinks={alternateLinks}
>

<!-- Noise overlay -->
<div class="noise-overlay" aria-hidden="true"></div>

<!-- ─── NAVBAR ─── -->
<nav class="navbar" id="navbar">
  <div class="navbar-inner">
    <a class="navbar-brand" href={path}>SAT-SCALE AI</a>

    <div class="navbar-links">
      <a class="nav-link" href="#technology" data-nav-target="technology">{copy.nav.technology}</a>
      <a class="nav-link" href="#showcase" data-nav-target="showcase">{copy.nav.showcase}</a>
      <a class="nav-link" href="#pricing" data-nav-target="pricing">{copy.nav.pricing}</a>
      <a class="nav-link" href="#contact" data-nav-target="contact">{copy.nav.enterprise}</a>
    </div>

    <div class="navbar-actions">
      <div class="language-switcher" aria-label={copy.language}>
        <a class="language-link" href="/v2/" aria-current={lang === 'es' ? 'page' : undefined}>ES</a>
        <a class="language-link" href="/v2/en/" aria-current={lang === 'en' ? 'page' : undefined}>EN</a>
      </div>
      <a class="btn-primary-pill" href="#contact" data-contact-intent="demo">{copy.nav.getStarted}</a>
    </div>

    <!-- Mobile: solo CTA + burger -->
    <div class="navbar-mobile-actions">
      <a class="btn-primary-pill" href="#contact" data-contact-intent="demo">{copy.nav.getStarted}</a>
      <button
        class="burger-btn"
        id="burger-btn"
        aria-label="Abrir menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="burger-bar"></span>
        <span class="burger-bar"></span>
        <span class="burger-bar"></span>
      </button>
    </div>
  </div>
  <div class="navbar-border" aria-hidden="true"></div>

  <!-- Mobile panel -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <a class="mobile-nav-link" href="#technology" data-nav-target="technology">{copy.nav.technology}</a>
    <a class="mobile-nav-link" href="#showcase" data-nav-target="showcase">{copy.nav.showcase}</a>
    <a class="mobile-nav-link" href="#pricing" data-nav-target="pricing">{copy.nav.pricing}</a>
    <a class="mobile-nav-link" href="#contact" data-nav-target="contact">{copy.nav.enterprise}</a>
    <div class="mobile-divider" aria-hidden="true"></div>
    <div class="language-switcher" aria-label={copy.language}>
      <a class="language-link" href="/v2/" aria-current={lang === 'es' ? 'page' : undefined}>ES</a>
      <a class="language-link" href="/v2/en/" aria-current={lang === 'en' ? 'page' : undefined}>EN</a>
    </div>
  </div>
</nav>

<main id="top">

  <!-- ─── HERO ─── -->
  <section class="hero-v2">
    <div class="hero-bg" aria-hidden="true">
      <img
        src="https://lh3.googleusercontent.com/aida-public/AB6AXuByvI5xrrQQTPKRGzDrZEZ0bVBwmKeXdlvpMj0_ZDYkwS-iu88UQWEJZKTB-Imee7FNpWp9-19dM73YmP6A9hX6RnRIo-HM8a9FcRriBnUq5h8STX71BJDJ3j1UglKaXPRc-70tizbfqlI_jvbpc1y7jPLWJbmRVAfBLzrD1-snkSeNG4S5hejWCj0_qB6ZzJH2xMHmk8cqnHyZ2wX0pfCXD051xzEtTlMKKy8Ge6-C1Ma_x9XNoG1H3I44L8vOsJjO8Le_DvkFpmA"
        alt={copy.alts.hero}
      />
      <div class="hero-overlay" aria-hidden="true"></div>
    </div>

    <div class="container">
      <div class="hero-content">
        <div class="hero-eyebrow">
          <span class="eyebrow-line" aria-hidden="true"></span>
          <span class="eyebrow-text">{t.hero_v2.eyebrow}</span>
        </div>

        <h1 class="hero-title">
          {t.hero_v2.titleLine1} <br /><span class="text-cyan">{t.hero_v2.titleAccent}</span>
        </h1>

        <p class="hero-subtitle">{t.hero_v2.subtitle}</p>

        <div class="hero-btns">
          <a class="btn-cyan-lg" href="#contact" data-contact-intent="demo">{t.hero_v2.primaryCta}</a>
          <a class="btn-outline-lg" href="#showcase">{t.hero_v2.secondaryCta}</a>
        </div>
      </div>

      <div class="hero-coords" aria-hidden="true">
        <p><span class="coord-key">COORD_X</span> 34.0522° N</p>
        <p><span class="coord-key">COORD_Y</span> 118.2437° W</p>
        <p><span class="coord-key">ALTITUDE</span> 400.0 KM</p>
        <p><span class="coord-key">INSTRUMENT</span> {t.hero_v2.instrument}</p>
      </div>
    </div>
  </section>

  <!-- ─── TECHNOLOGY ─── -->
  <section class="tech-section" id="technology">
    <div class="container">
      <div class="tech-grid">

        <div class="tech-copy" data-scroll-anchor>
          <div>
            <h2 class="section-title" set:html={copy.tech.title}></h2>
            <p class="section-body">{copy.tech.body}</p>
          </div>

          <div class="tech-features">
            {copy.tech.features.map((feature) => (
              <div class="tech-feature">
                <span class="material-symbols-outlined icon-cyan">{feature.icon}</span>
                <h4>{feature.title}</h4>
                <p>{feature.body}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="tech-images">
          <div class="tech-glow" aria-hidden="true"></div>
          <div class="tech-img-grid">
            <div class="tech-img-card">
              <img
                src="https://lh3.googleusercontent.com/aida-public/AB6AXuCr1WjyWES-qsyozk5fStfGoXlxJPGlnIdaYN4GgtQyFK44qF0mTb4A9_36uwj2CW-COPbFoscT9KiB6ifUflg7o1w0zHYlRD_999-nwvTfKYtUebruY-hayzFPmiIoACT6K72FeLCktHmVOOc2UV5g2OeCXiw2Cd3XQFkEwOxhHdcPJP9WEsFo1CtJBIjsgxKH_LvWBuOmc5U26YltNSQzGBxnW1O_-mUnm7EhFquPsCIKRcb2ltyBonOEtxmTCagRWmI1lP3UKbc"
                alt={copy.alts.techOne}
              />
            </div>
            <div class="tech-img-card tech-img-card--offset">
              <img
                src="https://lh3.googleusercontent.com/aida-public/AB6AXuBGuCetbHe7q7055fmC2P46fEFtqbWg0KSKbm9NLw0gD2foxyhN6GQDiygqrvZVwZFWDd8gDj2LKMoi0qRRJj9LvJ_KRaQDVvFtQN8966mArU2ZQbpdfYP4lI4E8XNoD7Zb840AAXYTKiBM0sk3Yuzl21aE2Yjw_4yEVUB5kglrrPbhOF9YpezlDzZo_hrzOwkCpT75qi-GrONOhwqcDsdyYJwWfYzfQjhLPrLBkFJyGCVtoabcC1rBm1--lAC_P7wmDqedDXIJcYo"
                alt={copy.alts.techTwo}
              />
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── COMPARISON ─── -->
  <section class="comparison-section" id="showcase">
    <div class="container">
      <div class="section-header" data-scroll-anchor>
        <h2 class="section-title">{copy.comparison.title}</h2>
        <p class="section-body">{copy.comparison.body}</p>
      </div>

      <div class="comparison-widget" id="comparison-widget">
        <!-- High-res (background) -->
        <div class="comparison-layer comparison-layer--back">
          <img
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuCXrwDz5Xu2-etNIpebLrLfGeLfkVwP3Eby_ADNzlqjSKWBNIERzzXkxka0Q89myfqqjQOU4wX8_WaUbPBPmSt466mL8X7-OHb4gxA5xiVN9FvqbcrxlYrMCilQy7TuqAi_IwEEK3aZV6RedYRj8MTmUaLOxp7f1gf9KK0YoEMvNWgCfG3viw6Dz1rE09wZtgdM_Stq9bJEq9WOUrzvX7-1f3SdUUx7WgeL43HbXooxu6q01USqKrrp3w_kyYyBygQ9hdk9ayMPo3Q"
            alt={copy.alts.comparisonBack}
          />
          <div class="comparison-badge comparison-badge--right">{copy.comparison.synthetic}</div>
        </div>

        <!-- Low-res (clipped overlay) -->
        <div class="comparison-layer comparison-layer--front" id="comparison-front">
          <img
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuBjKZDpypUq6dI_33QD2w2b43FsTBG0sHCOwZLUWx-1laXGE62ifhI0iULywCxir_0ci0e6ljgAJPxqc2Y3_3zswg0eAbRVG3TG-sXnJP926oazYp29fLMj9Ruv6h3yvDEO42Sin0iEXZ-6H4E9LL8A-5OS3XRWcHFmvjT9jJ-Zb2_wiSpJDgzNCOCSLtWyumftcHGpmwTE-oa-CuFeA5pgnYKAN_n_J2iqAiDMs-MRepo8CFn-Am_oWFkcLCYKmlsqPheGbf0F1K4"
            alt={copy.alts.comparisonFront}
          />
          <div class="comparison-badge comparison-badge--left">{copy.comparison.raw}</div>
        </div>

        <!-- Slider handle -->
        <div class="slider-handle" id="slider-handle" aria-hidden="true">
          <div class="slider-arrows">
            <span class="material-symbols-outlined">chevron_left</span>
            <span class="material-symbols-outlined">chevron_right</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── BENTO GRID (Strategic Verticals) ─── -->
  <section class="bento-section">
    <div class="container">
      <div class="bento-header">
        <h2 class="bento-title">{t.verticals_v2.sectionTitle}<br />{t.verticals_v2.sectionTitleAccent}</h2>
        <p class="bento-desc">{t.verticals_v2.subtitle}</p>
      </div>

      <div class="bento-grid">

        <!-- Card 1 – Urban Planning (wide) -->
        <div class="bento-card bento-card--wide">
          <img
            class="bento-bg"
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuDKj508O4VlxhIPRHNXbQzobwNSnQhrELQCihR8dXblYyJISvGYpGZVZE4QLT6r2I8X4MBa2TZbEdiEjY5ie7IqkrYZGDhEm-DzMt9tNwMdrcvC5n9hnPNoAxTQPT0z-GgO8mVo9nGj3MTcA4kbjE_dERViIpYYu8bvIo_Wb2ifHxzPCwlfTbJKw-_cmhAJ8Ee6CYaMzYDZWf0GHKFo4qYpjq9yaR2nd8tU8JXyAtQpXmn3Y7MPA0ucnRTaAzoRuLI5z0sYC-xyP8c"
            alt={copy.alts.verticalOne}
          />
          <div class="bento-copy">
            <span class="bento-kicker">{t.verticals_v2.items[0].kicker}</span>
            <h3 class="bento-card-title">{t.verticals_v2.items[0].title}</h3>
            <p class="bento-card-body">{t.verticals_v2.items[0].body}</p>
          </div>
          <div class="bento-footer">
            <span class="material-symbols-outlined bento-icon">{t.verticals_v2.items[0].icon}</span>
            <a class="bento-cta" href="#contact" data-contact-intent="enterprise">
              {t.verticals_v2.items[0].cta} <span class="material-symbols-outlined">arrow_forward</span>
            </a>
          </div>
        </div>

        <!-- Card 2 – Agri-Tech (narrow) -->
        <div class="bento-card bento-card--narrow">
          <img
            class="bento-bg"
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuButo2SODZ2ILBrsAcJUxgcwTaftJOefyVa0RC8fyenfFIgOyXON5G_Wdbp-VibrzZJc6tDypVoEaQBKZeAAR1mB1dk7hLMx-AXtqdQs3uMD5oEQSFwrtaBCSeKrhUxXULj8zzRMEDm1OOPDotAcF1ZJ7RxYBrvhQOJT5GXI-vhVbAI2NtHoJjCso1UsEeZ2uAN2xe4Rfid0DKeXL9-6PsED6v1aCtHBtMizFCVdVfTDHpmaWxKYzvjYtpBcC2cX767rYobK2eIgn0"
            alt={copy.alts.verticalTwo}
          />
          <div class="bento-copy">
            <span class="bento-kicker">{t.verticals_v2.items[1].kicker}</span>
            <h3 class="bento-card-title">{t.verticals_v2.items[1].title}</h3>
            <p class="bento-card-body">{t.verticals_v2.items[1].body}</p>
          </div>
          <span class="material-symbols-outlined bento-icon">{t.verticals_v2.items[1].icon}</span>
        </div>

        <!-- Card 3 – Ecosystem (medium-narrow) -->
        <div class="bento-card bento-card--med">
          <img
            class="bento-bg"
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuBro4C0mBGkbZ_n7BbxG62bFUfitBm1U5Pv12EDrKyk41Vddzjc3bJOTJKtz8t4RAWIOdiQm41KCgBlINZ-2kpoPPv0g1PFg96S049xfwXRhnYOuBBwpbUAUDWqv5S9Mgntg8oeFt0a4IaFkahCYmPdtcb121RXd_WvoVoFHmqgeWbwrqi7fGmtEhG-NE5ju5fbdlZDrxfRCNJFbsNvta0H8Yb-y7tGD8WAMd7N5E33gCPywB0YfBy9wTaJaYI6LRgUSnQ45FEY1Bo"
            alt={copy.alts.verticalThree}
          />
          <div class="bento-copy">
            <span class="bento-kicker">{t.verticals_v2.items[2].kicker}</span>
            <h3 class="bento-card-title">{t.verticals_v2.items[2].title}</h3>
            <p class="bento-card-body">{t.verticals_v2.items[2].body}</p>
          </div>
          <span class="material-symbols-outlined bento-icon">{t.verticals_v2.items[2].icon}</span>
        </div>

        <!-- Card 4 – Supply Systems (medium-wide) -->
        <div class="bento-card bento-card--med-wide">
          <img
            class="bento-bg"
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuDdmx84SGauVAKoEP-_iUWnQ8bUkNZnoANsM5QBNlvlqLzhvTstiFz9qjVQriLm7kyhpC5g9hFsZNhwxx453ohvvypJPNaqasEQsW65D0SSXvBiQT1VJAlyrLogw4ZzcYOgomC85CAMeNyB_0RdxRWOK_39_E5HttgX8vdNHpGWHqcB8M5DKZmCrEmFQ21t6XYKX-ycw9otEJT6DyuF6wPDtfrYJnpVw8n4FvtXBzivY5DJ-X7LXASHuSQwaRWCVCfZT52Abq9W8CU"
            alt={copy.alts.verticalFour}
          />
          <div class="bento-copy">
            <span class="bento-kicker">{t.verticals_v2.items[3].kicker}</span>
            <h3 class="bento-card-title">{t.verticals_v2.items[3].title}</h3>
            <p class="bento-card-body">{t.verticals_v2.items[3].body}</p>
          </div>
          <span class="material-symbols-outlined bento-icon">{t.verticals_v2.items[3].icon}</span>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── PRICING ─── -->
  <section class="pricing-section" id="pricing">
    <div class="container">
      <div class="section-header" data-scroll-anchor>
        <h2 class="section-title">{t.pricing_v2.sectionTitle}</h2>
        <p class="section-body">{t.pricing_v2.subtitle}</p>
      </div>

      <div class="pricing-grid">

        <!-- Standard -->
        <div class="pricing-card">
          <div class="pricing-tier">{t.pricing_v2.tiers[0].name}</div>
          <div class="pricing-price">{t.pricing_v2.tiers[0].price}<span class="pricing-period">{t.pricing_v2.tiers[0].period}</span></div>
          <ul class="pricing-features">
            {t.pricing_v2.tiers[0].features.map((feature) => (
              <li class:list={['pricing-feature', feature.included ? 'pricing-feature--on' : 'pricing-feature--off']}>
                {feature.included && <span class="feature-dot"></span>} {feature.label}
              </li>
            ))}
          </ul>
          <a class="btn-tier-outline" href="#contact" data-contact-intent="pricing">{t.pricing_v2.ctaStandard}</a>
        </div>

        <!-- Advanced (featured) -->
        <div class="pricing-card pricing-card--featured">
          <div class="pricing-badge">{t.pricing_v2.recommended}</div>
          <div class="pricing-tier pricing-tier--featured">{t.pricing_v2.tiers[1].name}</div>
          <div class="pricing-price">{t.pricing_v2.tiers[1].price}<span class="pricing-period">{t.pricing_v2.tiers[1].period}</span></div>
          <ul class="pricing-features">
            {t.pricing_v2.tiers[1].features.map((feature) => (
              <li class:list={['pricing-feature', feature.included ? 'pricing-feature--on' : 'pricing-feature--off']}>
                {feature.included && <span class="feature-dot"></span>} {feature.label}
              </li>
            ))}
          </ul>
          <a class="btn-tier-cyan" href="#contact" data-contact-intent="pricing">{t.pricing_v2.ctaAdvanced}</a>
        </div>

        <!-- Sovereign -->
        <div class="pricing-card">
          <div class="pricing-tier">{t.pricing_v2.tiers[2].name}</div>
          <div class="pricing-price pricing-price--custom">{t.pricing_v2.tiers[2].price}</div>
          <ul class="pricing-features">
            {t.pricing_v2.tiers[2].features.map((feature) => (
              <li class:list={['pricing-feature', feature.included ? 'pricing-feature--on' : 'pricing-feature--off']}>
                {feature.included && <span class="feature-dot"></span>} {feature.label}
              </li>
            ))}
          </ul>
          <a class="btn-tier-outline" href="#contact" data-contact-intent="enterprise">{t.pricing_v2.ctaSovereign}</a>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── CTA ─── -->
  <section class="cta-section" id="contact">
    <div class="cta-glow" aria-hidden="true"></div>
    <div class="container">
      <div class="cta-header" data-scroll-anchor>
        <p class="cta-kicker">{copy.form.kicker}</p>
        <h2 class="cta-title">{copy.form.title}</h2>
      </div>

      <div class="contact-form-card">
        <form
          class="contact-form-v2"
          id="contact-form-v2"
          method="post"
          data-endpoint={endpoint}
          data-fallback-email={fallbackEmail}
          data-fallback-notice={copy.form.fallbackNotice}
          data-success-message={copy.form.success}
          data-error-message={copy.form.error}
          data-busy-label={copy.form.busy}
          data-subject-prefix={copy.form.subjectPrefix}
        >
          <div class="contact-grid">
            <label class="contact-field">
              <span>{t.contact.nameLabel}</span>
              <input
                name="name"
                type="text"
                required
                autocomplete="name"
                placeholder={t.contact.namePlaceholder}
              />
            </label>

            <label class="contact-field">
              <span>{t.contact.emailLabel}</span>
              <input
                name="email"
                type="email"
                required
                autocomplete="email"
                placeholder={t.contact.emailPlaceholder}
              />
            </label>

            <label class="contact-field">
              <span>{copy.form.teamLabel}</span>
              <input
                name="org"
                type="text"
                required
                autocomplete="organization"
                placeholder={copy.form.teamPlaceholder}
              />
            </label>

            <label class="contact-field">
              <span>{copy.form.requestLabel}</span>
              <select name="request_type" id="contact-request-type" required>
                {copy.form.requestOptions.map(([value, label]) => (
                  <option value={value}>{label}</option>
                ))}
              </select>
            </label>

            <label class="contact-field contact-field-full">
              <span>{copy.form.useCaseLabel}</span>
              <textarea
                name="message"
                rows="4"
                placeholder={copy.form.useCasePlaceholder}
              ></textarea>
            </label>

            <input class="contact-honeypot" name="company_website" type="text" tabindex="-1" autocomplete="off" />
          </div>

          <div class="contact-actions-v2">
            <button class="btn-cyan-xl contact-submit-v2" type="submit">{copy.form.submit}</button>
            <p class="contact-privacy-v2">{copy.form.privacy}</p>
          </div>

          <p class="contact-status-v2" id="contact-status-v2" role="status" aria-live="polite"></p>
        </form>
      </div>
    </div>
  </section>

</main>

<!-- ─── FOOTER ─── -->
<footer class="footer-v2">
  <div class="footer-inner">
    <a class="footer-brand" href={path}>SAT-SCALE</a>
    <div class="footer-copy">{copy.footer.copy}</div>
  </div>
</footer>

</PageLayoutV2>

