<script>
  if (typeof window !== 'undefined') {
    window.addEventListener('DOMContentLoaded', () => {
      const navbar = document.getElementById('navbar');
      const navLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-nav-target]'));
      const sections = Array.from(document.querySelectorAll<HTMLElement>('section[id]'));
      if (!navLinks.length || !sections.length) return;

      const setActive = (id: string) => {
        navLinks.forEach((link) => {
          if (link.dataset.navTarget === id) {
            link.setAttribute('aria-current', 'location');
          } else {
            link.removeAttribute('aria-current');
          }
        });
      };

      const getSectionFromHash = () => {
        const hash = window.location.hash.replace('#', '');
        return sections.some((section) => section.id === hash) ? hash : '';
      };

      const scrollToSectionAnchor = (id: string, behavior: ScrollBehavior) => {
        const section = sections.find((item) => item.id === id);
        if (!section) return;
        const anchor = section.querySelector<HTMLElement>('[data-scroll-anchor]') ?? section;
        const navbarHeight = navbar?.offsetHeight ?? 0;
        const top = anchor.getBoundingClientRect().top + window.scrollY - navbarHeight - 24;
        window.scrollTo({ top: Math.max(0, top), behavior });
      };

      const syncFromViewport = () => {
        const fromHash = getSectionFromHash();
        if (fromHash) {
          setActive(fromHash);
          return;
        }

        const offset = 160;
        let current = sections[0]?.id ?? '';
        sections.forEach((section) => {
          if (section.offsetTop - offset <= window.scrollY) {
            current = section.id;
          }
        });
        if (current) setActive(current);
      };

      navLinks.forEach((link) => {
        link.addEventListener('click', (event) => {
          const id = link.dataset.navTarget;
          if (!id) return;
          event.preventDefault();
          history.pushState(null, '', `#${id}`);
          setActive(id);
          scrollToSectionAnchor(id, 'smooth');
        });
      });

      window.addEventListener('hashchange', () => {
        const id = getSectionFromHash();
        if (id) {
          setActive(id);
          scrollToSectionAnchor(id, 'auto');
        } else {
          syncFromViewport();
        }
      });
      window.addEventListener('scroll', syncFromViewport, { passive: true });

      const initialHash = getSectionFromHash();
      if (initialHash) {
        setActive(initialHash);
        window.requestAnimationFrame(() => scrollToSectionAnchor(initialHash, 'auto'));
      } else {
        syncFromViewport();
      }
    });
  }
</script>

<script>
  if (typeof window !== 'undefined') {
    window.addEventListener('DOMContentLoaded', () => {
      const form = document.querySelector<HTMLFormElement>('#contact-form-v2');
      const status = document.querySelector<HTMLElement>('#contact-status-v2');
      const submit = form?.querySelector<HTMLButtonElement>('button[type="submit"]');
      const requestType = document.getElementById('contact-request-type') as HTMLSelectElement | null;
      const sourceField = document.getElementById('contact-source-cta') as HTMLInputElement | null;
      const triggers = document.querySelectorAll<HTMLElement>('[data-contact-intent]');
      if (!form || !requestType || !sourceField) return;

      const endpoint = form.dataset.endpoint ?? '';
      const fallbackEmail = form.dataset.fallbackEmail ?? 'contact@satscale.ai';
      const fallbackNotice = form.dataset.fallbackNotice ?? '';
      const successMessage = form.dataset.successMessage ?? '';
      const errorMessage = form.dataset.errorMessage ?? '';
      const busyLabel = form.dataset.busyLabel ?? submit?.textContent ?? '';
      const subjectPrefix = form.dataset.subjectPrefix ?? 'SatScale';
      const originalSubmit = submit?.textContent ?? '';

      const setStatus = (message: string, state: 'idle' | 'success' | 'error') => {
        if (!status) return;
        status.textContent = message;
        status.dataset.state = state;
      };

      const applyIntent = (intent: string, source: string) => {
        requestType.value = intent;
        sourceField.value = source;
      };

      applyIntent('demo', sourceField.value);

      triggers.forEach((trigger) => {
        trigger.addEventListener('click', () => {
          const intent = trigger.dataset.contactIntent ?? 'info';
          const source = trigger.textContent?.trim() || sourceField.value;
          applyIntent(intent, source);
        });
      });

      form.addEventListener('submit', (event) => {
        event.preventDefault();
        setStatus('', 'idle');

        if (!form.reportValidity()) return;

        const data = new FormData(form);
        if ((data.get('company_website') ?? '').toString().trim()) return;

        const fallbackToMail = () => {
          const fields = [
            ['Name', (data.get('name') ?? '').toString()],
            ['Email', (data.get('email') ?? '').toString()],
            ['Organization', (data.get('org') ?? '').toString()],
            ['Request', (data.get('request_type') ?? '').toString()],
            ['Preferred date', (data.get('preferred_date') ?? '').toString()],
            ['Preferred time window', (data.get('schedule_window') ?? '').toString()],
            ['Source', (data.get('source_cta') ?? '').toString()],
            ['Message', (data.get('message') ?? '').toString()]
          ];
          const request = (data.get('request_type') ?? '').toString() || 'contact';
          const subject = encodeURIComponent(`${subjectPrefix} - ${request}`);
          const body = encodeURIComponent(fields.map(([label, value]) => `${label}: ${value}`).join('\n'));
          setStatus(fallbackNotice, 'idle');
          window.location.href = `mailto:${fallbackEmail}?subject=${subject}&body=${body}`;
        };

        const submitRequest = async () => {
          submit?.setAttribute('disabled', 'true');
          if (submit) submit.textContent = busyLabel;

          try {
            if (!endpoint) {
              fallbackToMail();
              return;
            }

            const response = await fetch(endpoint, {
              method: 'POST',
              body: data,
              headers: {
                Accept: 'application/json'
              }
            });

            if (!response.ok) throw new Error(`Request failed with ${response.status}`);

            form.reset();
            applyIntent('demo', 'Conversion');
            setStatus(successMessage, 'success');
          } catch (error) {
            console.error(error);
            setStatus(errorMessage, 'error');
          } finally {
            submit?.removeAttribute('disabled');
            if (submit) submit.textContent = originalSubmit;
          }
        };

        submitRequest();
      });
    });
  }
</script>

<script>
  if (typeof window !== 'undefined') {
    window.addEventListener('DOMContentLoaded', () => {
      const burger = document.getElementById('burger-btn') as HTMLButtonElement | null;
      const menu   = document.getElementById('mobile-menu') as HTMLElement | null;
      if (!burger || !menu) return;

      const close = () => {
        burger.setAttribute('aria-expanded', 'false');
        menu.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      };

      burger.addEventListener('click', () => {
        const open = burger.getAttribute('aria-expanded') === 'true';
        if (open) {
          close();
        } else {
          burger.setAttribute('aria-expanded', 'true');
          menu.setAttribute('aria-hidden', 'false');
          document.body.style.overflow = 'hidden';
        }
      });

      // Cerrar al hacer click en un link del menú
      menu.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', close);
      });

      // Cerrar si se expande la pantalla
      window.matchMedia('(min-width: 769px)').addEventListener('change', (e) => {
        if (e.matches) close();
      });
    });
  }
</script>

<script>
  // Comparison slider interaction
  if (typeof window !== 'undefined') {
    window.addEventListener('DOMContentLoaded', () => {
      const widget = document.getElementById('comparison-widget') as HTMLElement | null;
      const front = document.getElementById('comparison-front') as HTMLElement | null;
      const handle = document.getElementById('slider-handle') as HTMLElement | null;
      if (!widget || !front || !handle) return;

      let dragging = false;
      let pointerId: number | null = null;

      const setPosition = (x: number) => {
        const rect = widget.getBoundingClientRect();
        let pct = ((x - rect.left) / rect.width) * 100;
        pct = Math.max(5, Math.min(95, pct));
        front.style.width = pct + '%';
        handle.style.left = pct + '%';
      };

      const stopDragging = () => {
        dragging = false;
        pointerId = null;
        widget.classList.remove('is-dragging');
      };

      handle.addEventListener('pointerdown', (event) => {
        dragging = true;
        pointerId = event.pointerId;
        widget.classList.add('is-dragging');
        handle.setPointerCapture(event.pointerId);
        setPosition(event.clientX);
      });

      handle.addEventListener('pointermove', (event) => {
        if (!dragging || pointerId !== event.pointerId) return;
        setPosition(event.clientX);
      });

      handle.addEventListener('pointerup', stopDragging);
      handle.addEventListener('pointercancel', stopDragging);
      window.addEventListener('pointerup', stopDragging);
    });
  }
</script>
